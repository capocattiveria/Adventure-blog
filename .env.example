# Adventure Blog — Configuration Template
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# .env is git-ignored and never committed.

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL credentials. POSTGRES_PASSWORD is required.
POSTGRES_USER=adventure
POSTGRES_PASSWORD=change_me
POSTGRES_DB=adventure_blog

# ── Security ───────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Must be a long random string.
# Generate one with:  openssl rand -base64 32
JWT_SECRET=change_me_run_openssl_rand_base64_32

# ── URLs ───────────────────────────────────────────────────────────────────────
# Origin allowed by the backend CORS policy.
# Set this to the public URL of your frontend (e.g. https://blog.example.com).
CORS_ORIGIN=http://localhost:3000

# Public URL of the backend API, embedded into the frontend at build time.
# Set this to the public URL of your backend (e.g. https://api.example.com).
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Ports (optional) ───────────────────────────────────────────────────────────
# Uncomment and change if ports 8080 or 3000 are already in use on your host.
# BACKEND_PORT=8080
# WEB_PORT=3000
